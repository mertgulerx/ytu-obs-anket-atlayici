{
  "manifest_version": 3,
  "name": "Anket Otomasyonu",
  "version": "1.0",
  "description": "Ders değerlendirme anketlerini otomatik olarak doldurur.",
  "content_scripts": [
    {
      "matches": [
        "*://*/*/eva_form_start.aspx*",
        "*://*/*/eva_form.aspx*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
